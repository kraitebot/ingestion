APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ingestion
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Kraite Configuration
# Global kill-switch for trading operations (default: false)
CAN_TRADE=false

# Allow opening new positions (default: false)
CAN_OPEN_POSITIONS=false

# Enable/disable all notifications globally (default: true)
# Set to false in production to prevent notification spam during data refresh
NOTIFICATIONS_ENABLED=true

# Prefix notification titles/subjects with hostname (default: false)
# e.g., "[DELLXPS15] Slow Database Query Detected"
PREFIX_HOSTNAME_ON_NOTIFICATIONS=false

# Log queries slower than this threshold in milliseconds (default: 2500)
SLOW_QUERY_THRESHOLD_MS=2500

# Emit extra info-level logs (default: false)
INFO_IF=false

# Step Logging
# Enable file-based logging for steps (default: false)
# Logs are written to storage/logs/steps/{step_id}/step.log
STEP_RELATED_LOGGING=false

# Server Health Check Secrets
# Each server validates health-check requests against its own secret.
# These are stored in the database and sent by the dashboard via X-Health-Token header.
SERVER_SECRET_WORKER1=
SERVER_SECRET_WORKER2=
SERVER_SECRET_WORKER3=
SERVER_SECRET_WORKER4=
SERVER_SECRET_WORKER5=
SERVER_SECRET_INGESTION=

# Local server's own health check secret (validated by this server's /health-check endpoint)
HEALTH_CHECK_SECRET=

# Trader Configuration - Binance+Bybit User
TRADER_BB_NAME=
TRADER_BB_EMAIL=
TRADER_BB_PASSWORD=
TRADER_BB_PUSHOVER_KEY=
TRADER_BB_BINANCE_API_KEY=
TRADER_BB_BINANCE_API_SECRET=
TRADER_BB_BYBIT_API_KEY=
TRADER_BB_BYBIT_API_SECRET=

# Trader Configuration - Binance Only User
TRADER_B_NAME=
TRADER_B_EMAIL=
TRADER_B_PASSWORD=
TRADER_B_PUSHOVER_KEY=
TRADER_B_BINANCE_API_KEY=
TRADER_B_BINANCE_API_SECRET=

# Trader Configuration - Kraite primary trader (owner of Main Binance Account)
TRADER_KRAITE_NAME=
TRADER_KRAITE_EMAIL=
TRADER_KRAITE_PASSWORD=
TRADER_KRAITE_PUSHOVER_KEY=
